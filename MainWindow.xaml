<Window x:Class="GridGameProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tetris Vize Projesi" Height="600" Width="400"
        KeyDown="Window_KeyDown"
        Background="#222222">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="150"/>
        </Grid.ColumnDefinitions>

        <Canvas x:Name="GameCanvas" Grid.Column="0" Background="#111111" Margin="10" ClipToBounds="True"/>

        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10">
            <TextBlock Text="SKOR" Foreground="White" FontSize="20" HorizontalAlignment="Center"/>
            <TextBlock x:Name="ScoreText" Text="0" Foreground="Yellow" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="EN YÜKSEK SKOR" Foreground="LightGray" FontSize="14" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
            <TextBlock x:Name="HighScoreText" Text="0" Foreground="Orange" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <TextBlock x:Name="GameOverText" Text="OYUN BİTTİ!" Foreground="Red" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Visibility="Hidden"/>
        </StackPanel>
    </Grid>
</Window>